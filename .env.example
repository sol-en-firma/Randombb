# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Vercel Blob Configuration
BLOB_READ_WRITE_TOKEN=your-blob-token-here

# Cron Job Secret (for security)
CRON_SECRET=your-secret-cron-token-here

# App URL (used for auth callbacks)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Development only (v0 specific)
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=https://v0-fresco-kitchen-assistant.vercel.app/
